# v0 JSON-file storage (default)
DATA_FILE=./data/ghost-data.json

# MongoDB (unused in v0 — kept for future swap-in)
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/ghost?retryWrites=true&w=majority

# HTTP server port
PORT=8080

# Matching epoch duration in ms
EPOCH_MS=5000

# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
